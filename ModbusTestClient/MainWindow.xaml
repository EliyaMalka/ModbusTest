<Window x:Class="ModbusTestClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ModbusTestClient.Converters"
        xmlns:vm="clr-namespace:ModbusTestClient.ViewModels"
        Title="Modbus TCP Test Client" 
        Height="820" Width="1100" 
        MinHeight="700" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColor"/>
        <converters:BoolToConnectionTextConverter x:Key="BoolToConnText"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:LogLevelToColorConverter x:Key="LogToColor"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ TOP: Connection Panel ============ -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="16,12" Margin="0,0,0,10"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- IP Address -->
                    <StackPanel Margin="0,0,16,0">
                        <Label Style="{StaticResource FieldLabel}" Content="IP Address"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="160" IsEnabled="{Binding IsNotConnected}"/>
                    </StackPanel>

                    <!-- Port -->
                    <StackPanel Margin="0,0,16,0">
                        <Label Style="{StaticResource FieldLabel}" Content="Port"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" IsEnabled="{Binding IsNotConnected}"/>
                    </StackPanel>

                    <!-- Slave ID -->
                    <StackPanel Margin="0,0,16,0">
                        <Label Style="{StaticResource FieldLabel}" Content="Slave ID"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="60" IsEnabled="{Binding IsNotConnected}"/>
                    </StackPanel>

                    <!-- Timeout -->
                    <StackPanel Margin="0,0,16,0">
                        <Label Style="{StaticResource FieldLabel}" Content="Timeout (ms)"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" IsEnabled="{Binding IsNotConnected}"/>
                    </StackPanel>

                    <!-- Connect / Disconnect Buttons -->
                    <StackPanel Margin="0,0,8,0" VerticalAlignment="Bottom">
                        <Button Style="{StaticResource SuccessButton}" Content="Connect" 
                                Command="{Binding ConnectCommand}" Width="100"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        <Button Style="{StaticResource DangerButton}" Content="Disconnect" 
                                Command="{Binding DisconnectCommand}" Width="100"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Connection Status -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnText}}" 
                               Foreground="{Binding IsConnected, Converter={StaticResource BoolToColor}, ConverterParameter=connection}"
                               FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#888" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ MIDDLE: Operations + Results ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Operations Panel (Tabs) -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="0" Margin="0,0,10,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <TabControl Background="Transparent" BorderThickness="0" Padding="0" Margin="4">

                    <!-- Tab: Read Registers FC3 -->
                    <TabItem Header="📖 Read Registers">
                        <StackPanel Margin="14">
                            <TextBlock Text="FC3 — Read Holding Registers" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                       Foreground="#0078D4"/>

                            <Label Style="{StaticResource FieldLabel}" Content="Start Address"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ReadRegStartAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <Label Style="{StaticResource FieldLabel}" Content="Quantity"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ReadRegQuantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <Button Style="{StaticResource PrimaryButton}" Content="📖  Read Registers" 
                                    Command="{Binding ReadHoldingRegistersCommand}" HorizontalAlignment="Stretch"/>

                            <Separator Margin="0,16,0,12"/>

                            <!-- Auto Refresh -->
                            <TextBlock Text="Auto Refresh" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="Enable" IsChecked="{Binding AutoRefreshEnabled}" VerticalAlignment="Center" Margin="0,0,12,0"
                                          IsEnabled="{Binding IsConnected}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding AutoRefreshInterval, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="80"/>
                                <TextBlock Text=" ms" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- Tab: Write Single FC6 -->
                    <TabItem Header="✏️ Write Single">
                        <StackPanel Margin="14">
                            <TextBlock Text="FC6 — Write Single Register" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                       Foreground="#107C10"/>

                            <Label Style="{StaticResource FieldLabel}" Content="Address"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WriteSingleAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <Label Style="{StaticResource FieldLabel}" Content="Value (decimal or 0xHex)"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WriteSingleValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <Button Style="{StaticResource SuccessButton}" Content="✏️  Write Register" 
                                    Command="{Binding WriteSingleRegisterCommand}" HorizontalAlignment="Stretch"/>

                            <Border Background="#F0FFF0" CornerRadius="4" Padding="10" Margin="0,16,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#555">
                                    <Run FontWeight="SemiBold">Tip:</Run>
                                    <Run Text="You can enter values in decimal (e.g. 1234) or hex (e.g. 0x04D2). Valid range: 0 - 65535."/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <!-- Tab: Write Multiple FC16 -->
                    <TabItem Header="📝 Write Multi">
                        <StackPanel Margin="14">
                            <TextBlock Text="FC16 — Write Multiple Registers" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                       Foreground="#8B5CF6"/>

                            <Label Style="{StaticResource FieldLabel}" Content="Start Address"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WriteMultiStartAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <Label Style="{StaticResource FieldLabel}" Content="Values (comma separated)"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WriteMultiValues, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,4" Height="60" TextWrapping="Wrap" AcceptsReturn="False"
                                     VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Text="e.g.: 100, 200, 0xFF, 400" FontSize="11" Foreground="#888" Margin="0,0,0,12"/>

                            <Button Style="{StaticResource PrimaryButton}" Content="📝  Write Registers" 
                                    Command="{Binding WriteMultipleRegistersCommand}" HorizontalAlignment="Stretch"
                                    Background="#8B5CF6"/>
                        </StackPanel>
                    </TabItem>

                    <!-- Tab: Coils FC1/FC5 -->
                    <TabItem Header="🔘 Coils">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="14">
                                <TextBlock Text="FC1 — Read Coils" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                           Foreground="#E67E00"/>

                                <Label Style="{StaticResource FieldLabel}" Content="Start Address"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ReadCoilStartAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Style="{StaticResource FieldLabel}" Content="Quantity"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ReadCoilQuantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                                <Button Style="{StaticResource PrimaryButton}" Content="🔘  Read Coils" 
                                        Command="{Binding ReadCoilsCommand}" HorizontalAlignment="Stretch"
                                        Background="#E67E00"/>

                                <Separator Margin="0,20,0,16"/>

                                <TextBlock Text="FC5 — Write Single Coil" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                           Foreground="#D13438"/>

                                <Label Style="{StaticResource FieldLabel}" Content="Address"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WriteCoilAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Label Style="{StaticResource FieldLabel}" Content="Value:" VerticalAlignment="Center"/>
                                    <ToggleButton Content="{Binding WriteCoilValue}" IsChecked="{Binding WriteCoilValue}" 
                                                  Width="70" Height="30" Margin="8,0,8,0"/>
                                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                                               Text="{Binding WriteCoilValue, StringFormat={}{0}}"
                                               Foreground="{Binding WriteCoilValue, Converter={StaticResource BoolToColor}, ConverterParameter=coil}"/>
                                </StackPanel>

                                <Button Style="{StaticResource DangerButton}" Content="🔘  Write Coil" 
                                        Command="{Binding WriteSingleCoilCommand}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Tab: Batch Test -->
                    <TabItem Header="🧪 Batch Test">
                        <StackPanel Margin="14">
                            <TextBlock Text="Batch Test" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                                       Foreground="#0078D4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#555" Margin="0,0,0,16">
                                Runs a complete test suite that writes and reads back registers and coils to verify connectivity and data integrity with your Modbus server.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888" Margin="0,0,0,4">
                                <Run FontWeight="SemiBold">Tests include:</Run>
                            </TextBlock>
                            <TextBlock Text="1. FC6: Write single register (addr 0)" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="2. FC3: Read back and verify" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="3. FC16: Write multiple registers (addr 10-12)" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="4. FC3: Read back and verify" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="5. FC5: Write coil ON (addr 0)" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="6. FC1: Read coil and verify ON" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="7. FC5: Write coil OFF (addr 0)" FontSize="11" Foreground="#555" Margin="8,2,0,0"/>
                            <TextBlock Text="8. FC1: Read coil and verify OFF" FontSize="11" Foreground="#555" Margin="8,2,0,16"/>

                            <Button Style="{StaticResource PrimaryButton}" Content="🧪  Run Batch Test" 
                                    Command="{Binding RunBatchTestCommand}" HorizontalAlignment="Stretch" FontSize="14" Padding="16,12"/>

                            <Border Background="#FFF8E7" CornerRadius="4" Padding="10" Margin="0,16,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#665500">
                                    <Run FontWeight="SemiBold">Note:</Run>
                                    <Run Text="This test writes to registers 0 and 10-12, and coil 0. Make sure these addresses are available in your simulator."/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- Right: Results Panel -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="12" 
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Register Results -->
                    <TextBlock Grid.Row="0" Text="📊 Register Results" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RegisterResults}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" BorderBrush="#E0E0E0"
                              AlternatingRowBackground="#FAFAFA"
                              RowHeight="28" ColumnHeaderHeight="32"
                              Margin="0,0,0,12"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="70"/>
                            <DataGridTextColumn Header="Value (Dec)" Binding="{Binding Value}" Width="90"/>
                            <DataGridTextColumn Header="Value (Hex)" Binding="{Binding HexValue}" Width="90"/>
                            <DataGridTextColumn Header="Binary" Binding="{Binding BinaryValue}" Width="150"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimestampStr}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Coil Results -->
                    <TextBlock Grid.Row="2" Text="🔘 Coil Results" FontWeight="Bold" FontSize="14" Margin="0,4,0,8"/>
                    <DataGrid Grid.Row="3" ItemsSource="{Binding CoilResults}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" BorderBrush="#E0E0E0"
                              AlternatingRowBackground="#FAFAFA"
                              RowHeight="28" ColumnHeaderHeight="32"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="80"/>
                            <DataGridTextColumn Header="State" Binding="{Binding StateText}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Value" Binding="{Binding Value}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimestampStr}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============ BOTTOM: Log Panel ============ -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="12" Margin="0,10,0,0"
                BorderBrush="#E0E0E0" BorderThickness="1" MaxHeight="220">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="📋 Communication Log" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource PrimaryButton}" Content="Export" Command="{Binding ExportLogCommand}" 
                                Padding="12,4" FontSize="11" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource DangerButton}" Content="Clear" Command="{Binding ClearLogCommand}" 
                                Padding="12,4" FontSize="11"/>
                    </StackPanel>
                </DockPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" 
                         BorderThickness="1" BorderBrush="#E8E8E8" 
                         Background="#FAFAFA"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <TextBlock Text="{Binding TimestampStr}" Foreground="#888" FontSize="11" FontFamily="Consolas" Width="85"/>
                                <TextBlock Text="{Binding LevelText}" FontSize="11" FontWeight="SemiBold" Width="55"
                                           Foreground="{Binding Level, Converter={StaticResource LogToColor}}" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding Direction}" FontSize="11" Foreground="#0078D4" Width="35" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding Message}" FontSize="11" TextWrapping="Wrap" FontFamily="Consolas"
                                           Foreground="{Binding Level, Converter={StaticResource LogToColor}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F0F0F0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Busy Indicator -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#40000000" CornerRadius="6"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳ Processing..." FontSize="18" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
